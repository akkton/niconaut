{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:cf": "npm run build && wrangler pages dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "db:create": "wrangler d1 create niconaut-comments",
    "db:migrate:local": "wrangler d1 migrations apply niconaut-comments --local",
    "db:migrate:remote": "wrangler d1 migrations apply niconaut-comments --remote",
    "db:console": "wrangler d1 execute niconaut-comments --remote --command"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20251101.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.0.0"
  }
}
