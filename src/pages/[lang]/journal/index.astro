---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
import { SITE_TITLE } from '../../../consts';
import { LOCALES, useJournal, type Locale } from '../../../i18n/ui';

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== 'en').map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const j = useJournal(lang);
const localeTag = lang === 'pt' ? 'pt-BR' : lang === 'de' ? 'de-DE' : 'en-US';

const entries = (await getCollection('journal', ({ data }) => !data.draft && data.lang === lang)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

type EntryRow = (typeof entries)[number];
type MonthBucket = { month: number; monthName: string; rows: EntryRow[] };
type YearBucket = { year: number; months: MonthBucket[] };

const monthName = (m: number) =>
	new Date(Date.UTC(2026, m, 1)).toLocaleDateString(localeTag, { month: 'long', timeZone: 'UTC' });

const grouped: YearBucket[] = [];
for (const entry of entries) {
	const d = entry.data.date;
	const y = d.getUTCFullYear();
	const m = d.getUTCMonth();
	let yearBucket = grouped.find((g) => g.year === y);
	if (!yearBucket) {
		yearBucket = { year: y, months: [] };
		grouped.push(yearBucket);
	}
	let monthBucket = yearBucket.months.find((mm) => mm.month === m);
	if (!monthBucket) {
		monthBucket = { month: m, monthName: monthName(m), rows: [] };
		yearBucket.months.push(monthBucket);
	}
	monthBucket.rows.push(entry);
}

const dayLabel = (d: Date) => d.toLocaleDateString(localeTag, { day: '2-digit', timeZone: 'UTC' });
const weekdayLabel = (d: Date) => d.toLocaleDateString(localeTag, { weekday: 'short', timeZone: 'UTC' });

const titleFromSummary = (s: string) => {
	const firstSentence = s.split(/(?<=[.!?])\s+/)[0];
	return firstSentence.length > 80 ? firstSentence.slice(0, 80).trim() + '…' : firstSentence;
};
const entryLabel = (entry: EntryRow): string => entry.data.title ?? titleFromSummary(entry.data.summary);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${j.pageTitle} · ${SITE_TITLE}`} description={j.pageSub} />
		<style>
			.page-head { margin: 0 0 3em 0; }
			.page-head h1 { margin: 0 0 0.35em 0; font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; }
			.page-head p { margin: 0; color: var(--ink-muted); font-size: 0.95rem; line-height: 1.5; max-width: 55ch; }
			.year { margin: 0 0 2em 0; }
			.year-head { display: flex; align-items: baseline; justify-content: space-between; padding: 0.4em 0; margin: 0 0 1em 0; border-bottom: 1px solid var(--rule-strong); }
			.year-head h2 { margin: 0; font-family: var(--font-stack-mono); font-size: 0.95rem; font-weight: 500; letter-spacing: 0.02em; color: var(--ink); }
			.year-count { font-family: var(--font-stack-mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.04em; }
			.month { margin: 0 0 1.5em 0; }
			.month-head { margin: 0 0 0.5em 0; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-faint); }
			ul.entries { list-style: none; margin: 0; padding: 0; }
			ul.entries li { padding: 0.55em 0; border-bottom: 1px solid var(--rule); }
			ul.entries li:last-child { border-bottom: none; }
			ul.entries a { display: grid; grid-template-columns: 4.5em 1fr auto 1.25em; gap: 0.6em 1em; align-items: baseline; color: var(--ink); text-decoration: none; transition: opacity 0.12s ease; }
			ul.entries a:hover { opacity: 0.65; }
			.e-day { font-family: var(--font-stack-mono); font-size: 12px; color: var(--ink-faint); letter-spacing: 0.02em; }
			.e-title { font-size: 14px; color: var(--ink); line-height: 1.45; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
			.e-hours { font-family: var(--font-stack-mono); font-size: 11px; color: var(--ink-faint); white-space: nowrap; letter-spacing: 0.02em; text-align: right; }
			.arrow { font-family: var(--font-stack-mono); color: var(--ink-faint); opacity: 0; }
			.empty { color: var(--ink-faint); font-style: italic; }
			@media (max-width: 540px) {
				ul.entries a { grid-template-columns: 4em 1fr auto; }
				.arrow { display: none; }
				.e-title { white-space: normal; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1>{j.pageTitle}</h1>
				<p>{j.pageSub}</p>
			</section>

			{grouped.length === 0 ? (
				<p class="empty">{j.entriesCount(0)}</p>
			) : (
				grouped.map((yearBucket) => (
					<section class="year">
						<div class="year-head">
							<h2>{yearBucket.year}</h2>
							<span class="year-count">{j.entriesCount(yearBucket.months.reduce((acc, m) => acc + m.rows.length, 0))}</span>
						</div>
						{yearBucket.months.map((monthBucket) => (
							<div class="month">
								<h3 class="month-head">{monthBucket.monthName}</h3>
								<ul class="entries">
									{monthBucket.rows.map((entry) => (
										<li>
											<a href={`/${lang}/journal/${entry.data.translationKey ?? entry.id}/`}>
												<span class="e-day">{weekdayLabel(entry.data.date)} {dayLabel(entry.data.date)}</span>
												<span class="e-title">{entryLabel(entry)}</span>
												<span class="e-hours">{entry.data.focusTime ?? ''}</span>
												<span class="arrow" aria-hidden="true">&rarr;</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						))}
					</section>
				))
			)}

			<NewsletterSignup lang={lang} />
		</main>
		<Footer />
	</body>
</html>
