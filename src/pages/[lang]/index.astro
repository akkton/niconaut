---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { SITE_TITLE } from '../../consts';
import { LOCALES, useTranslations, type Locale } from '../../i18n/ui';

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== 'en').map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const hero: Record<string, { tagline: string; intro: string; desc: string }> = {
	pt: {
		tagline: 'Curioso por oportunidades. Construindo coisas. Documentando a bagunça.',
		intro: 'Estou construindo produtos com agentes de IA, registrando o trabalho em público e descobrindo como é uma vida empreendedora em 2026. Este é o registro.',
		desc: 'Construindo, aprendendo e escrevendo em público.',
	},
	de: {
		tagline: 'Neugierig auf Chancen. Dinge bauen. Das Chaos dokumentieren.',
		intro: 'Ich baue Produkte mit KI-Agenten, dokumentiere die Arbeit öffentlich und finde heraus, wie ein unternehmerisches Leben 2026 aussieht. Das ist das Logbuch.',
		desc: 'Bauen, lernen und öffentlich dokumentieren.',
	},
};

const recentJournal = (await getCollection('journal', ({ data }) => !data.draft && data.lang === lang))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);

const recentPosts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === lang))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={SITE_TITLE} description={hero[lang].desc} />
		<style>
			.hero { margin: 0 0 3em 0; }
			.hero h1 { margin: 0 0 0.35em 0; font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; }
			.hero .tagline { margin: 0 0 1em 0; font-size: 1rem; color: var(--ink-muted); font-style: italic; line-height: 1.45; }
			.hero p { margin: 0; color: var(--ink-muted); font-size: 0.95rem; line-height: 1.6; max-width: 55ch; }
			section { margin-bottom: 3em; }
			.section-head { display: flex; align-items: baseline; justify-content: space-between; margin: 0 0 1em 0; padding-bottom: 0.4em; border-bottom: 1px solid var(--rule); }
			.section-head h2 { margin: 0; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-faint); }
			.section-head .all-link { font-size: 0.78rem; color: var(--ink-faint); text-decoration: none; letter-spacing: 0.02em; }
			.section-head .all-link:hover { color: var(--ink); }
			.journal-list, .posts-list { list-style: none; margin: 0; padding: 0; }
			.journal-list li { padding: 0.6em 0; border-bottom: 1px solid var(--rule); }
			.journal-list li:last-child { border-bottom: none; }
			.journal-list a { display: grid; grid-template-columns: 7em 1fr auto; gap: 0.75em 1em; align-items: baseline; color: var(--ink); text-decoration: none; }
			.journal-list a:hover { opacity: 0.65; }
			.j-date { font-family: var(--font-stack-mono); font-size: 12px; color: var(--ink-faint); white-space: nowrap; }
			.j-title { margin: 0 0 0.15em 0; font-size: 14.5px; font-weight: 600; color: var(--ink); line-height: 1.3; }
			.j-summary { margin: 0; font-size: 13.5px; color: var(--ink-muted); line-height: 1.45; }
			.j-hours { font-family: var(--font-stack-mono); font-size: 11px; color: var(--ink-faint); white-space: nowrap; }
			.posts-list li { padding: 1em 0; border-bottom: 1px solid var(--rule); }
			.posts-list li:last-child { border-bottom: none; }
			.posts-list a { display: block; color: var(--ink); text-decoration: none; }
			.posts-list a:hover .p-title { color: var(--link-hover); }
			.p-title { margin: 0 0 0.2em 0; font-size: 1rem; font-weight: 600; }
			.p-date { margin: 0 0 0.35em 0; font-family: var(--font-stack-mono); font-size: 11px; color: var(--ink-faint); }
			.p-desc { margin: 0; color: var(--ink-muted); font-size: 14px; line-height: 1.5; }
			.empty { color: var(--ink-faint); font-style: italic; font-size: 14px; margin: 0; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Nico Neumann</h1>
				<p class="tagline">{hero[lang].tagline}</p>
				<p>{hero[lang].intro}</p>
			</section>

			{recentJournal.length > 0 && (
				<section>
					<div class="section-head">
						<h2>{t.headings.recentJournal}</h2>
						<a href={`/${lang}/journal`} class="all-link">{t.labels.allEntries} &rarr;</a>
					</div>
					<ul class="journal-list">
						{recentJournal.map((entry) => (
							<li>
								<a href={`/${lang}/journal/${entry.data.translationKey ?? entry.id}/`}>
									<span class="j-date"><FormattedDate date={entry.data.date} short weekday /></span>
									<div>
										{entry.data.title && <p class="j-title">{entry.data.title}</p>}
										<p class="j-summary">{entry.data.summary}</p>
									</div>
									<span class="j-hours">{entry.data.focusTime ?? ''}</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}

			<section>
				<div class="section-head">
					<h2>{t.headings.recentPosts}</h2>
					<a href={`/${lang}/posts`} class="all-link">{t.labels.allPosts} &rarr;</a>
				</div>
				{recentPosts.length === 0 ? (
					<p class="empty">{t.labels.noPosts}</p>
				) : (
					<ul class="posts-list">
						{recentPosts.map((post) => (
							<li>
								<a href={`/${lang}/posts/${post.data.translationKey ?? post.id}/`}>
									<h3 class="p-title">{post.data.title}</h3>
									<p class="p-date"><FormattedDate date={post.data.pubDate} /></p>
									<p class="p-desc">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>

			<NewsletterSignup lang={lang} />
		</main>
		<Footer />
	</body>
</html>
