---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { LOCALES, useTranslations, type Locale } from '../../i18n/ui';

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== 'en').map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

type AboutCopy = {
	title: string;
	lede: string;
	feeds: { journal: string; posts: string };
	whyHead: string;
	why: string;
	howHead: string;
	how: string;
	contactHead: string;
	contactLead: string;
};

const copy: Record<string, AboutCopy> = {
	pt: {
		title: 'Sobre',
		lede: 'Sou Nicolas Neumann (Nico). Construo com agentes de IA, lanço produtos e documento o caminho aqui. Dois fluxos:',
		feeds: {
			journal: 'Diário: entradas diárias, horas de foco, o que foi entregue, lições.',
			posts: 'Artigos: textos mais longos sobre construir em público, marcos e decisões.',
		},
		whyHead: 'Por que isto existe',
		why: 'Três razões. Primeiro, como prova de mim mesmo: um histórico documentado que posso mostrar a investidores, parceiros ou qualquer pessoa que queira saber se eu apareço de forma consistente e penso com clareza. Segundo, como forma de manter contato com amigos, família e pessoas que eu perderia de vista de outra maneira. Terceiro, porque escrever o trabalho me obriga a entendê-lo.',
		howHead: 'Como este site é feito',
		how: 'Astro e MDX, hospedado no Cloudflare Pages, com o conteúdo escrito através do Claude Code. Todo o pipeline de publicação roda no mesmo sistema de agentes de IA que uso para construir o resto dos meus produtos. Meta, no bom sentido.',
		contactHead: 'Contato',
		contactLead: 'E-mail:',
	},
	de: {
		title: 'Über mich',
		lede: 'Ich bin Nicolas Neumann (Nico). Ich baue mit KI-Agenten, bringe Produkte heraus und dokumentiere den Weg hier. Zwei Stränge:',
		feeds: {
			journal: 'Tagebuch: tägliche Einträge, Fokuszeit, was fertig wurde, Lektionen.',
			posts: 'Beiträge: längere Texte über das Bauen in der Öffentlichkeit, Meilensteine und Entscheidungen.',
		},
		whyHead: 'Warum es das gibt',
		why: 'Drei Gründe. Erstens als Beweis über mich selbst: ein dokumentierter Werdegang, den ich Investoren, Mitstreitern oder jedem zeigen kann, der wissen will, ob ich verlässlich auftauche und klar denke. Zweitens, um mit Freunden, Familie und Menschen in Kontakt zu bleiben, die ich sonst aus den Augen verlieren würde. Drittens, weil das Aufschreiben der Arbeit mich zwingt, sie zu verstehen.',
		howHead: 'Wie diese Seite gebaut ist',
		how: 'Astro und MDX, gehostet auf Cloudflare Pages, die Inhalte über Claude Code geschrieben. Die gesamte Veröffentlichung läuft über dasselbe KI-Agenten-System, mit dem ich auch den Rest meiner Produkte baue. Meta, im guten Sinne.',
		contactHead: 'Kontakt',
		contactLead: 'E-Mail:',
	},
};

const c = copy[lang];
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${c.title} · ${SITE_TITLE}`} description={c.lede} />
		<style>
			.page-head { margin: 0 0 2.5em 0; }
			.page-head h1 { margin: 0 0 0.25em 0; font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; }
			h2 { margin: 2em 0 0.5em 0; font-size: 1.05rem; font-weight: 600; color: var(--ink); }
			p { line-height: 1.65; color: var(--ink); font-size: 15px; max-width: 60ch; }
			ul { margin: 0 0 1.25em 0; padding-left: 1.2em; color: var(--ink); font-size: 14.5px; line-height: 1.65; }
			.lede { color: var(--ink-muted); font-size: 1rem; }
			a { color: var(--ink); }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1>{c.title}</h1>
				<p class="lede">{c.lede}</p>
			</section>
			<ul>
				<li><a href={`/${lang}/journal`}>{t.nav.journal}</a>: {c.feeds.journal}</li>
				<li><a href={`/${lang}/posts`}>{t.nav.posts}</a>: {c.feeds.posts}</li>
			</ul>

			<h2>{c.whyHead}</h2>
			<p>{c.why}</p>

			<h2>{c.howHead}</h2>
			<p>{c.how}</p>

			<h2>{c.contactHead}</h2>
			<p>
				{c.contactLead} <a href="mailto:neumanic2@gmail.com">neumanic2@gmail.com</a>.
				<a href="https://www.linkedin.com/in/nicolas-neumann-520736286/" target="_blank" rel="noopener">LinkedIn</a>,
				<a href="https://github.com/akkton" target="_blank" rel="noopener">GitHub</a>,
				<a href="https://www.instagram.com/nickswagster/" target="_blank" rel="noopener">Instagram</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
