---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const entries = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Journal · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 1em;
			}
			h1 {
				margin: 0 0 0.25em 0;
				font-family: var(--font-atkinson), system-ui, sans-serif;
			}
			.subtitle {
				margin: 0 0 2em 0;
				color: rgb(var(--gray));
				font-style: italic;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				padding: 1em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li a {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em 1.5em;
				align-items: baseline;
				text-decoration: none;
				color: inherit;
			}
			ul li a:hover .summary {
				color: rgb(var(--accent));
			}
			.date {
				min-width: 9ch;
				font-family: var(--font-atkinson), system-ui, sans-serif;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.summary {
				flex: 1;
				min-width: 240px;
				margin: 0;
				color: rgb(var(--gray-dark));
			}
			.hours {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.empty {
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Journal</h1>
			<p class="subtitle">Daily log: hours, what shipped, what didn't, what I learned.</p>
			{entries.length === 0 ? (
				<p class="empty">No entries yet.</p>
			) : (
				<ul>
					{entries.map((entry) => (
						<li>
							<a href={`/journal/${entry.id}/`}>
								<span class="date"><FormattedDate date={entry.data.date} /></span>
								<p class="summary">{entry.data.summary}</p>
								{entry.data.hoursWorked !== undefined && (
									<span class="hours">{entry.data.hoursWorked}h</span>
								)}
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
