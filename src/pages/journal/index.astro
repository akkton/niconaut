---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { SITE_TITLE } from '../../consts';

const entries = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const MONTH_NAMES = [
	'January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December',
];

type EntryRow = (typeof entries)[number];
type MonthBucket = { month: number; monthName: string; rows: EntryRow[] };
type YearBucket = { year: number; months: MonthBucket[] };

const grouped: YearBucket[] = [];
for (const entry of entries) {
	const d = entry.data.date;
	const y = d.getUTCFullYear();
	const m = d.getUTCMonth();
	let yearBucket = grouped.find((g) => g.year === y);
	if (!yearBucket) {
		yearBucket = { year: y, months: [] };
		grouped.push(yearBucket);
	}
	let monthBucket = yearBucket.months.find((mm) => mm.month === m);
	if (!monthBucket) {
		monthBucket = { month: m, monthName: MONTH_NAMES[m], rows: [] };
		yearBucket.months.push(monthBucket);
	}
	monthBucket.rows.push(entry);
}

const dayLabel = (d: Date) =>
	d.toLocaleDateString('en-us', { day: '2-digit', timeZone: 'UTC' });

const titleFromSummary = (s: string) => {
	const firstSentence = s.split(/(?<=[.!?])\s+/)[0];
	return firstSentence.length > 80 ? firstSentence.slice(0, 80).trim() + '…' : firstSentence;
};

const entryLabel = (entry: EntryRow): string =>
	entry.data.title ?? titleFromSummary(entry.data.summary);

const weekdayLabel = (d: Date) =>
	d.toLocaleDateString('en-us', { weekday: 'short', timeZone: 'UTC' });
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Journal · ${SITE_TITLE}`} description="Daily log: hours, what shipped, what didn't, what I learned." />
		<style>
			.page-head {
				margin: 0 0 3em 0;
			}
			.page-head h1 {
				margin: 0 0 0.35em 0;
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.page-head p {
				margin: 0;
				color: var(--ink-muted);
				font-size: 0.95rem;
				line-height: 1.5;
				max-width: 55ch;
			}

			.year {
				margin: 0 0 2em 0;
			}
			.year-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				padding: 0.4em 0;
				margin: 0 0 1em 0;
				border-bottom: 1px solid var(--rule-strong);
			}
			.year-head h2 {
				margin: 0;
				font-family: var(--font-stack-mono);
				font-size: 0.95rem;
				font-weight: 500;
				letter-spacing: 0.02em;
				color: var(--ink);
			}
			.year-count {
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.04em;
			}

			.month {
				margin: 0 0 1.5em 0;
			}
			.month-head {
				margin: 0 0 0.5em 0;
				font-size: 0.78rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}

			ul.entries {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.entries li {
				padding: 0.55em 0;
				border-bottom: 1px solid var(--rule);
			}
			ul.entries li:last-child {
				border-bottom: none;
			}
			ul.entries a {
				display: grid;
				grid-template-columns: 4.5em 1fr auto 1.25em;
				gap: 0.6em 1em;
				align-items: baseline;
				color: var(--ink);
				text-decoration: none;
				transition: opacity 0.12s ease;
			}
			ul.entries a:hover {
				opacity: 0.65;
			}
			ul.entries a:hover .arrow {
				opacity: 1;
				transform: translateX(2px);
			}
			.e-day {
				font-family: var(--font-stack-mono);
				font-size: 12px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.e-title {
				font-size: 14px;
				color: var(--ink);
				line-height: 1.45;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.e-hours {
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				white-space: nowrap;
				letter-spacing: 0.02em;
				text-align: right;
			}
			.arrow {
				font-family: var(--font-stack-mono);
				color: var(--ink-faint);
				opacity: 0;
				transition: opacity 0.12s ease, transform 0.12s ease;
			}

			.empty {
				color: var(--ink-faint);
				font-style: italic;
			}

			@media (max-width: 540px) {
				ul.entries a {
					grid-template-columns: 4em 1fr auto;
				}
				.arrow {
					display: none;
				}
				.e-title {
					white-space: normal;
					-webkit-line-clamp: 2;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1>Journal</h1>
				<p>Daily log: hours, what shipped, what didn't, what I learned. Newest first.</p>
			</section>

			{grouped.length === 0 ? (
				<p class="empty">No entries yet.</p>
			) : (
				grouped.map((yearBucket) => (
					<section class="year">
						<div class="year-head">
							<h2>{yearBucket.year}</h2>
							<span class="year-count">{yearBucket.months.reduce((acc, m) => acc + m.rows.length, 0)} entries</span>
						</div>
						{yearBucket.months.map((monthBucket) => (
							<div class="month">
								<h3 class="month-head">{monthBucket.monthName}</h3>
								<ul class="entries">
									{monthBucket.rows.map((entry) => (
										<li>
											<a href={`/journal/${entry.id}/`}>
												<span class="e-day">{weekdayLabel(entry.data.date)} {dayLabel(entry.data.date)}</span>
												<span class="e-title">{entryLabel(entry)}</span>
												<span class="e-hours">{entry.data.focusTime ?? ''}</span>
												<span class="arrow" aria-hidden="true">&rarr;</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						))}
					</section>
				))
			)}

			<NewsletterSignup />
		</main>
		<Footer />
	</body>
</html>
