---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import JournalLayout from '../../layouts/JournalLayout.astro';

export async function getStaticPaths() {
	const all = (await getCollection('journal', ({ data }) => !data.draft)).sort(
		(a, b) => a.data.date.valueOf() - b.data.date.valueOf(),
	);
	return all.map((entry, idx) => {
		const prev = idx > 0 ? all[idx - 1] : null;
		const next = idx < all.length - 1 ? all[idx + 1] : null;
		return {
			params: { slug: entry.id },
			props: {
				entry,
				prev: prev ? { slug: prev.id, date: prev.data.date, summary: prev.data.summary, title: prev.data.title } : null,
				next: next ? { slug: next.id, date: next.data.date, summary: next.data.summary, title: next.data.title } : null,
			},
		};
	});
}

type Props = {
	entry: CollectionEntry<'journal'>;
	prev: { slug: string; date: Date; summary: string; title?: string } | null;
	next: { slug: string; date: Date; summary: string; title?: string } | null;
};

const { entry, prev, next } = Astro.props as Props;
const { Content } = await render(entry);
---

<JournalLayout {...entry.data} prev={prev} next={next}>
	<Content />
</JournalLayout>
