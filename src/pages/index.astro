---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { personSchema } from '../lib/jsonld';
import aboutImg from '../assets/blog-placeholder-about.jpg';

const recentJournal = (await getCollection('journal', ({ data }) => !data.draft && data.lang === 'en'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);

const recentPosts = (await getCollection('posts', ({ data }) => !data.draft && data.lang === 'en'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} jsonLd={personSchema()} />
		<style>
			.hero {
				margin: 0 0 3.5em 0;
			}
			.hero h1 {
				margin: 0 0 0.35em 0;
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.hero .tagline {
				margin: 0 0 1em 0;
				font-size: 1rem;
				color: var(--ink-muted);
				font-style: italic;
				line-height: 1.45;
			}
			.hero p {
				margin: 0;
				color: var(--ink-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				max-width: 55ch;
			}

			.about-stanza {
				margin: 0 0 3.5em 0;
			}
			.about-figure {
				margin: 0 0 1.5em 0;
			}
			.about-figure img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 4px;
				border: 1px solid var(--rule);
			}
			.about-figure figcaption {
				margin: 0.55em 0 0 0;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.about-stanza p {
				margin: 0 0 0.85em 0;
				color: var(--ink);
				font-size: 0.95rem;
				line-height: 1.6;
				max-width: 60ch;
			}
			.about-stanza p:last-child {
				margin-bottom: 0;
			}
			.about-stanza a {
				color: var(--ink);
				text-decoration: underline;
				text-decoration-thickness: 1px;
				text-underline-offset: 3px;
			}
			.about-stanza a:hover {
				color: var(--link-hover);
			}

			section {
				margin-bottom: 3em;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin: 0 0 1em 0;
				padding-bottom: 0.4em;
				border-bottom: 1px solid var(--rule);
			}
			.section-head h2 {
				margin: 0;
				font-size: 0.78rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
			}
			.section-head .all-link {
				font-size: 0.78rem;
				color: var(--ink-faint);
				text-decoration: none;
				letter-spacing: 0.02em;
			}
			.section-head .all-link:hover {
				color: var(--ink);
			}

			.journal-list,
			.posts-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.journal-list li {
				padding: 0.6em 0;
				border-bottom: 1px solid var(--rule);
			}
			.journal-list li:last-child {
				border-bottom: none;
			}
			.journal-list a {
				display: grid;
				grid-template-columns: 7em 1fr auto;
				gap: 0.75em 1em;
				align-items: baseline;
				color: var(--ink);
				text-decoration: none;
				transition: opacity 0.12s ease;
			}
			.journal-list a:hover {
				opacity: 0.65;
			}
			.j-date {
				font-family: var(--font-stack-mono);
				font-size: 12px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
				white-space: nowrap;
			}
			.j-body {
				min-width: 0;
			}
			.j-title {
				margin: 0 0 0.15em 0;
				font-size: 14.5px;
				font-weight: 600;
				color: var(--ink);
				line-height: 1.3;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.j-summary {
				margin: 0;
				font-size: 13.5px;
				color: var(--ink-muted);
				line-height: 1.45;
				overflow: hidden;
				text-overflow: ellipsis;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
			}
			.j-hours {
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				white-space: nowrap;
				letter-spacing: 0.02em;
			}

			.posts-list li {
				padding: 1em 0;
				border-bottom: 1px solid var(--rule);
			}
			.posts-list li:last-child {
				border-bottom: none;
			}
			.posts-list a {
				display: block;
				color: var(--ink);
				text-decoration: none;
			}
			.posts-list a:hover .p-title {
				color: var(--link-hover);
			}
			.p-title {
				margin: 0 0 0.2em 0;
				font-size: 1rem;
				font-weight: 600;
			}
			.p-date {
				margin: 0 0 0.35em 0;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.p-desc {
				margin: 0;
				color: var(--ink-muted);
				font-size: 14px;
				line-height: 1.5;
			}
			.empty {
				color: var(--ink-faint);
				font-style: italic;
				font-size: 14px;
				margin: 0;
			}
			@media (max-width: 540px) {
				.journal-list a {
					grid-template-columns: 6em 1fr;
					grid-template-rows: auto auto;
				}
				.j-hours {
					grid-column: 2 / 3;
					grid-row: 2;
					font-size: 10px;
				}
				.j-summary {
					-webkit-line-clamp: 3;
				}
				.hero h1 {
					font-size: 1.7rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Nico Neumann</h1>
				<p class="tagline">Curious about opportunity. Building things. Documenting the mess.</p>
				<p>
					I'm building products with AI agents, journaling the work in public, and figuring out
					what an entrepreneurial life looks like in 2026. This is the log.
				</p>
			</section>

			<section class="about-stanza">
				<figure class="about-figure">
					<Image src={aboutImg} alt="A placeholder portrait. Real photo lands later." width={1020} height={680} />
					<figcaption>The log starts here.</figcaption>
				</figure>
				<p>
					Two streams. A near-daily journal tracks what I worked on, what shipped, what stalled,
					and the focus time from Rize. Long-form posts when an idea earns more than 200 words.
				</p>
				<p>
					Everything is plain text first. The repo is public. The analytics events are listed
					on <a href="/privacy/">/privacy</a>. If anything you read lands or fails to land,
					the <a href="/feedback/">/feedback</a> link comes straight to my inbox.
				</p>
			</section>

			<section>
				<div class="section-head">
					<h2>Recent journal</h2>
					<a href="/journal/" class="all-link">all entries &rarr;</a>
				</div>
				{recentJournal.length === 0 ? (
					<p class="empty">No entries yet.</p>
				) : (
					<ul class="journal-list">
						{recentJournal.map((entry) => (
							<li>
								<a href={`/journal/${entry.id}/`}>
									<span class="j-date"><FormattedDate date={entry.data.date} short weekday /></span>
									<div class="j-body">
										{entry.data.title && <p class="j-title">{entry.data.title}</p>}
										<p class="j-summary">{entry.data.summary}</p>
									</div>
									<span class="j-hours">{entry.data.focusTime ?? ''}</span>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>

			<section>
				<div class="section-head">
					<h2>Recent posts</h2>
					<a href="/posts/" class="all-link">all posts &rarr;</a>
				</div>
				{recentPosts.length === 0 ? (
					<p class="empty">No long-form posts yet. Building-in-public writing lands here.</p>
				) : (
					<ul class="posts-list">
						{recentPosts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<h3 class="p-title">{post.data.title}</h3>
									<p class="p-date"><FormattedDate date={post.data.pubDate} /></p>
									<p class="p-desc">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)}
			</section>

			<NewsletterSignup />
		</main>
		<Footer />
	</body>
</html>
