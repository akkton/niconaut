---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort((a, b) => {
	const ao = a.data.order ?? 999;
	const bo = b.data.order ?? 999;
	if (ao !== bo) return ao - bo;
	return b.data.startedDate.valueOf() - a.data.startedDate.valueOf();
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Building · ${SITE_TITLE}`} description="The projects I'm working on, with a running changelog for each." />
		<style>
			.page-head {
				margin: 0 0 2.5em 0;
			}
			.page-head h1 {
				margin: 0 0 0.35em 0;
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.page-head p {
				margin: 0;
				color: var(--ink-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				max-width: 60ch;
			}
			.project-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.project-list li {
				padding: 1.25em 0;
				border-bottom: 1px solid var(--rule);
			}
			.project-list li:last-child {
				border-bottom: none;
			}
			.project-list a {
				display: block;
				color: var(--ink);
				text-decoration: none;
			}
			.p-head {
				display: flex;
				align-items: baseline;
				gap: 0.75em;
				margin: 0 0 0.3em 0;
			}
			.p-name {
				margin: 0;
				font-size: 1.1rem;
				font-weight: 600;
			}
			.project-list a:hover .p-name {
				color: var(--link-hover);
			}
			.status {
				font-family: var(--font-stack-mono);
				font-size: 10px;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
				border: 1px solid var(--rule);
				border-radius: 999px;
				padding: 0.15em 0.6em;
				white-space: nowrap;
			}
			.p-summary {
				margin: 0 0 0.4em 0;
				color: var(--ink-muted);
				font-size: 14px;
				line-height: 1.55;
			}
			.p-since {
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.empty {
				color: var(--ink-faint);
				font-style: italic;
				font-size: 14px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1>Building</h1>
				<p>
					The things I'm working on, in the open. Each project has a running changelog and,
					over time, posts that follow it. Status is honest, not aspirational.
				</p>
			</section>

			{projects.length === 0 ? (
				<p class="empty">Nothing public yet.</p>
			) : (
				<ul class="project-list">
					{projects.map((project) => (
						<li>
							<a href={`/building/${project.id}/`}>
								<div class="p-head">
									<h2 class="p-name">{project.data.name}</h2>
									<span class="status">{project.data.status}</span>
								</div>
								<p class="p-summary">{project.data.summary}</p>
								<span class="p-since">since <FormattedDate date={project.data.startedDate} /></span>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
