---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FeedbackBlock from '../components/FeedbackBlock.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { blogPostingSchema } from '../lib/jsonld';
import { useTranslations, type Locale } from '../i18n/ui';

type Props = CollectionEntry<'posts'>['data'] & { slug: string; lang?: Locale; minutesRead?: number };

const { title, description, pubDate, updatedDate, heroImage, tags, slug, lang = 'en', minutesRead } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'en' ? '' : `/${lang}`;
const postsIndexPath = `${base}/posts/`;
const postPath = `${base}/posts/${slug}/`;

const postUrl = new URL(postPath, Astro.site).href;
const ogImage = heroImage
	? new URL(heroImage.src, Astro.site).href
	: new URL('/og-default.png', Astro.site).href;

const postJsonLd = blogPostingSchema({
	title,
	description,
	url: postUrl,
	datePublished: pubDate,
	dateModified: updatedDate,
	image: ogImage,
	tags,
});
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} jsonLd={postJsonLd} />
		<style>
			a.back-link {
				display: inline-block;
				margin-bottom: 1.5em;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				text-decoration: none;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			a.back-link:hover {
				color: var(--ink);
			}
			.hero-image {
				margin: 0 0 2em 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border: 1px solid var(--rule);
				border-radius: 4px;
			}
			.title {
				margin: 0 0 2em 0;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 1.9rem;
				font-weight: 700;
				letter-spacing: -0.02em;
				line-height: 1.2;
			}
			.title .desc {
				margin: 0 0 1em 0;
				color: var(--ink-muted);
				font-size: 1rem;
				line-height: 1.5;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em 0.75em;
				align-items: baseline;
				font-family: var(--font-stack-mono);
				font-size: 12px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.meta .sep {
				color: var(--ink-faint);
			}
			.meta .updated {
				color: var(--ink-faint);
			}
			.prose {
				color: var(--ink);
				font-size: 15px;
				line-height: 1.65;
			}
			.prose :global(p) {
				margin: 0 0 1.1em 0;
			}
			.prose :global(h2) {
				margin-top: 2em;
				font-size: 1.2rem;
				font-weight: 600;
			}
			.prose :global(h3) {
				margin-top: 1.5em;
				font-size: 1.05rem;
				font-weight: 600;
			}
			.prose :global(figure) {
				margin: 1.75em 0;
			}
			.prose :global(figure img) {
				display: block;
				width: 100%;
				height: auto;
				border: 1px solid var(--rule);
				border-radius: 4px;
			}
			.prose :global(figcaption) {
				margin-top: 0.5em;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				text-align: center;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<a href={postsIndexPath} class="back-link">&larr; {t.labels.backPosts}</a>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="title">
					<h1>{title}</h1>
					<p class="desc">{description}</p>
					<div class="meta">
						<span><FormattedDate date={pubDate} /></span>
						{minutesRead && <span class="sep">·</span>}
						{minutesRead && <span>{minutesRead} {t.labels.minRead}</span>}
						{updatedDate && <span class="sep">·</span>}
						{updatedDate && (
							<span class="updated">updated <FormattedDate date={updatedDate} /></span>
						)}
						{tags && tags.length > 0 && <span class="sep">·</span>}
						{tags && tags.length > 0 && <span>{tags.join(', ')}</span>}
					</div>
				</div>
				<div class="prose">
					<slot />
				</div>
				<FeedbackBlock
					headline={title}
					articleType="post"
					path={postPath}
				/>
			</article>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				var thresholds = [0.25, 0.5, 0.75, 1.0];
				var labels = { 0.25: 'article_read_25', 0.5: 'article_read_50', 0.75: 'article_read_75', 1.0: 'article_read_100' };
				var fired = {};
				function check() {
					var scrolled = window.scrollY + window.innerHeight;
					var total = document.documentElement.scrollHeight;
					if (total <= 0) return;
					var ratio = scrolled / total;
					for (var i = 0; i < thresholds.length; i++) {
						var t = thresholds[i];
						if (!fired[t] && ratio >= t) {
							fired[t] = true;
							if (window.posthog && typeof window.posthog.capture === 'function') {
								window.posthog.capture(labels[t], {
									path: window.location.pathname,
									article_type: 'post',
								});
							}
						}
					}
					if (fired[1.0]) window.removeEventListener('scroll', check);
				}
				window.addEventListener('scroll', check, { passive: true });
				window.addEventListener('load', check);
			})();
		</script>
	</body>
</html>
