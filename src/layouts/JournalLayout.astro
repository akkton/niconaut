---
import type { CollectionEntry } from 'astro:content';
import AccountabilityFooter from '../components/AccountabilityFooter.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RizeRecap from '../components/RizeRecap.astro';

type Props = CollectionEntry<'journal'>['data'];

const {
	date,
	hoursWorked,
	summary,
	tags,
	focusTime,
	topCategories,
	topApps,
	rizePartial,
	screenshot,
	targets,
	wins,
	losses,
	lessons,
} = Astro.props;
const showRecap = focusTime !== undefined || (topCategories && topCategories.length > 0);
const isoDate = date.toISOString().slice(0, 10);
---

<html lang="en">
	<head>
		<BaseHead title={`Journal · ${date.toISOString().slice(0, 10)}`} description={summary} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 1em;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75em 1.25em;
				align-items: baseline;
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.date {
				font-family: var(--font-atkinson), system-ui, sans-serif;
				font-size: 1.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1;
			}
			.hours {
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.tags {
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.tags span {
				margin-right: 0.5em;
			}
			.summary {
				margin: 0 0 1.5em 0;
				color: rgb(var(--gray-dark));
				font-style: italic;
				line-height: 1.5;
			}
			.body {
				color: rgb(var(--gray-dark));
			}
			.back {
				display: inline-block;
				margin-bottom: 1.5em;
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			.screenshot {
				margin: 0 0 2em 0;
				padding: 0;
			}
			.screenshot img {
				display: block;
				width: 100%;
				height: auto;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
			}
			.screenshot figcaption {
				margin-top: 0.5em;
				font-size: 0.8rem;
				color: rgb(var(--gray));
				text-align: center;
				letter-spacing: 0.04em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<a href="/journal/" class="back">&larr; All journal entries</a>
			<div class="meta">
				<span class="date"><FormattedDate date={date} /></span>
				{hoursWorked !== undefined && <span class="hours">{hoursWorked}h worked</span>}
				{tags && tags.length > 0 && (
					<span class="tags">
						{tags.map((t: string) => <span>#{t}</span>)}
					</span>
				)}
			</div>
			<p class="summary">{summary}</p>
			{showRecap && (
				<RizeRecap
					focusTime={focusTime}
					topCategories={topCategories}
					topApps={topApps}
					rizePartial={rizePartial}
				/>
			)}
			{screenshot && (
				<figure class="screenshot">
					<img src={screenshot} alt={`Rize day summary for ${isoDate}`} loading="lazy" />
					<figcaption>Day captured in Rize</figcaption>
				</figure>
			)}
			<div class="body">
				<slot />
			</div>
			<AccountabilityFooter
				targets={targets}
				wins={wins}
				losses={losses}
				lessons={lessons}
			/>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				var fired = false;
				function check() {
					if (fired) return;
					var scrolled = window.scrollY + window.innerHeight;
					var total = document.documentElement.scrollHeight;
					if (total <= 0) return;
					if (scrolled / total >= 0.5) {
						fired = true;
						if (window.posthog && typeof window.posthog.capture === 'function') {
							window.posthog.capture('article_read_50', {
								path: window.location.pathname,
								article_type: 'journal',
							});
						}
						window.removeEventListener('scroll', check);
					}
				}
				window.addEventListener('scroll', check, { passive: true });
				window.addEventListener('load', check);
			})();
		</script>
	</body>
</html>
