---
import type { CollectionEntry } from 'astro:content';
import AccountabilityFooter from '../components/AccountabilityFooter.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RizeRecap from '../components/RizeRecap.astro';

type NavRef = { slug: string; date: Date; summary: string } | null;

type Props = CollectionEntry<'journal'>['data'] & {
	prev?: NavRef;
	next?: NavRef;
};

const {
	date,
	writtenAt,
	hoursWorked,
	summary,
	tags,
	focusTime,
	topCategories,
	topApps,
	rizePartial,
	screenshot,
	targets,
	wins,
	losses,
	lessons,
	updates,
	prev,
	next,
} = Astro.props as Props;
const showRecap = focusTime !== undefined || (topCategories && topCategories.length > 0);
const isoDate = date.toISOString().slice(0, 10);

const shortTitle = (s: string) => {
	const firstSentence = s.split(/(?<=[.!?])\s+/)[0];
	return firstSentence.length > 60 ? firstSentence.slice(0, 60).trim() + '…' : firstSentence;
};
const shortDay = (d: Date) =>
	d.toLocaleDateString('en-us', { month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<html lang="en">
	<head>
		<BaseHead title={`Journal · ${isoDate}`} description={summary} />
		<style>
			a.back-link {
				display: inline-block;
				margin-bottom: 1.5em;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				text-decoration: none;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			a.back-link:hover {
				color: var(--ink);
			}
			.meta {
				margin: 0 0 1em 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em 0.75em;
				align-items: baseline;
				font-family: var(--font-stack-mono);
				font-size: 12px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
			}
			.meta .date {
				color: var(--ink);
				font-weight: 500;
			}
			.meta .sep {
				color: var(--ink-faint);
			}
			.meta .tags {
				color: var(--ink-faint);
			}
			.lede {
				margin: 0 0 2em 0;
				color: var(--ink-muted);
				font-size: 1rem;
				line-height: 1.55;
				max-width: 60ch;
			}

			.screenshot {
				margin: 0 0 2em 0;
				padding: 0;
			}
			.screenshot img {
				display: block;
				width: 100%;
				height: auto;
				border: 1px solid var(--rule);
				border-radius: 4px;
			}
			.screenshot figcaption {
				margin-top: 0.5em;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				text-align: center;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}

			.body {
				color: var(--ink);
				font-size: 15px;
				line-height: 1.65;
			}
			.body :global(p) {
				margin: 0 0 1.1em 0;
			}
			.body :global(h2) {
				margin-top: 2em;
				font-size: 1.2rem;
				font-weight: 600;
			}
			.body :global(h3) {
				margin-top: 1.5em;
				font-size: 1.05rem;
				font-weight: 600;
			}
			.body :global(ul),
			.body :global(ol) {
				margin: 0 0 1.1em 0;
				padding-left: 1.4em;
			}
			.body :global(li) {
				margin-bottom: 0.4em;
			}
			.body :global(blockquote) {
				margin: 1.5em 0;
				padding: 0.25em 0 0.25em 1em;
				border-left: 2px solid var(--rule-strong);
				color: var(--ink-muted);
			}

			.updates {
				margin: 2.5em 0 0 0;
				padding: 1.25em 0 0 0;
				border-top: 1px solid var(--rule);
			}
			.updates-label {
				font-size: 0.78rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-faint);
				margin: 0 0 0.85em 0;
			}
			.update {
				margin-bottom: 1.5em;
				padding-left: 1em;
				border-left: 2px solid var(--rule);
			}
			.update:last-child {
				margin-bottom: 0;
			}
			.update-at {
				display: block;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.02em;
				margin-bottom: 0.35em;
			}
			.update-note {
				color: var(--ink);
				font-size: 14px;
				line-height: 1.55;
				white-space: pre-line;
			}

			.prevnext {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1em;
				margin: 3em 0 0 0;
				padding: 1.25em 0;
				border-top: 1px solid var(--rule);
				border-bottom: 1px solid var(--rule);
			}
			.prevnext a {
				display: block;
				color: var(--ink-muted);
				text-decoration: none;
				font-size: 13px;
				line-height: 1.45;
				transition: color 0.12s ease;
			}
			.prevnext a:hover {
				color: var(--ink);
			}
			.prevnext .label {
				display: block;
				font-family: var(--font-stack-mono);
				font-size: 11px;
				color: var(--ink-faint);
				letter-spacing: 0.04em;
				text-transform: uppercase;
				margin-bottom: 0.25em;
			}
			.prevnext .right {
				text-align: right;
			}
			.prevnext .placeholder {
				color: var(--ink-faint);
				font-style: italic;
				font-size: 13px;
			}
			@media (max-width: 540px) {
				.prevnext {
					grid-template-columns: 1fr;
				}
				.prevnext .right {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<a href="/journal/" class="back-link">&larr; all journal</a>
			<div class="meta">
				<span class="date"><FormattedDate date={date} /></span>
				{writtenAt && <span class="sep">·</span>}
				{writtenAt && <span>written {writtenAt}</span>}
				{hoursWorked !== undefined && <span class="sep">·</span>}
				{hoursWorked !== undefined && <span>{hoursWorked}h worked</span>}
				{tags && tags.length > 0 && <span class="sep">·</span>}
				{tags && tags.length > 0 && (
					<span class="tags">{tags.join(', ')}</span>
				)}
			</div>
			<p class="lede">{summary}</p>
			{showRecap && (
				<RizeRecap
					focusTime={focusTime}
					topCategories={topCategories}
					topApps={topApps}
					rizePartial={rizePartial}
				/>
			)}
			{screenshot && (
				<figure class="screenshot">
					<img src={screenshot} alt={`Rize day summary for ${isoDate}`} loading="lazy" />
					<figcaption>Day captured in Rize</figcaption>
				</figure>
			)}
			<div class="body">
				<slot />
			</div>
			{updates && updates.length > 0 && (
				<section class="updates" aria-label="Later updates to this entry">
					<h2 class="updates-label">Later notes</h2>
					{updates.map((u) => (
						<div class="update">
							<span class="update-at">{u.at}</span>
							<div class="update-note">{u.note}</div>
						</div>
					))}
				</section>
			)}
			<nav class="prevnext" aria-label="Journal navigation">
				<div>
					{prev ? (
						<a href={`/journal/${prev.slug}/`}>
							<span class="label">&larr; previous</span>
							<span>{shortDay(prev.date)} · {shortTitle(prev.summary)}</span>
						</a>
					) : (
						<span class="placeholder">No earlier entry</span>
					)}
				</div>
				<div class="right">
					{next ? (
						<a href={`/journal/${next.slug}/`}>
							<span class="label">next &rarr;</span>
							<span>{shortDay(next.date)} · {shortTitle(next.summary)}</span>
						</a>
					) : (
						<span class="placeholder">Latest entry</span>
					)}
				</div>
			</nav>
			<AccountabilityFooter
				targets={targets}
				wins={wins}
				losses={losses}
				lessons={lessons}
			/>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				var fired = false;
				function check() {
					if (fired) return;
					var scrolled = window.scrollY + window.innerHeight;
					var total = document.documentElement.scrollHeight;
					if (total <= 0) return;
					if (scrolled / total >= 0.5) {
						fired = true;
						if (window.posthog && typeof window.posthog.capture === 'function') {
							window.posthog.capture('article_read_50', {
								path: window.location.pathname,
								article_type: 'journal',
							});
						}
						window.removeEventListener('scroll', check);
					}
				}
				window.addEventListener('scroll', check, { passive: true });
				window.addEventListener('load', check);
			})();
		</script>
	</body>
</html>
