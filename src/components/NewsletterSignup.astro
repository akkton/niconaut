---
// Newsletter signup, wired to Buttondown.
// On submit: fire the PostHog newsletter_signup_intent event (before anything else),
// then POST the email + preference (as a Buttondown tag) to the embed-subscribe
// endpoint via fetch (no-cors keeps the visitor on-site). Buttondown sends the
// double-opt-in confirmation email. Username lives in consts.ts (BUTTONDOWN_USERNAME).
import { BUTTONDOWN_USERNAME } from '../consts';

const subscribeAction = `https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`;
---

<section class="newsletter" aria-label="Email subscribe">
	<div class="head">
		<h2 class="title">Get this in your inbox</h2>
		<p class="sub">
			One email when a new piece lands. Sent through Buttondown, with a one-click
			unsubscribe in every email. No tracking pixels.
		</p>
	</div>
	<form id="newsletter-form" data-action={subscribeAction} novalidate>
		<label class="email-label" for="newsletter-email">Email</label>
		<input
			id="newsletter-email"
			type="email"
			name="email"
			placeholder="you@somewhere.com"
			required
		/>
		<fieldset class="prefs">
			<legend>I want…</legend>
			<label>
				<input type="radio" name="pref" value="both" checked />
				<span>Both</span>
			</label>
			<label>
				<input type="radio" name="pref" value="journal" />
				<span>Journal only</span>
			</label>
			<label>
				<input type="radio" name="pref" value="posts" />
				<span>Long-form posts only</span>
			</label>
		</fieldset>
		<button type="submit">Subscribe</button>
		<p class="confirm" role="status" hidden></p>
	</form>
</section>

<style>
	.newsletter {
		margin: 4em 0 2em 0;
		padding: 1.5em 1.5em 1.75em 1.5em;
		border: 1px solid var(--rule);
	}
	.head {
		margin-bottom: 1.25em;
	}
	.title {
		margin: 0 0 0.35em 0;
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--ink);
	}
	.sub {
		margin: 0;
		color: var(--ink-muted);
		font-size: 13.5px;
		line-height: 1.5;
		max-width: 55ch;
	}
	form {
		display: flex;
		flex-direction: column;
		gap: 0.85em;
	}
	.email-label {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-faint);
	}
	input[type="email"] {
		padding: 0.5em 0.65em;
		border: 1px solid var(--rule-strong);
		background: var(--bg);
		color: var(--ink);
		font-size: 14px;
		font-family: var(--font-stack-sans);
		border-radius: 0;
	}
	input[type="email"]:focus {
		outline: none;
		border-color: var(--ink);
	}
	.prefs {
		margin: 0;
		padding: 0;
		border: none;
	}
	.prefs legend {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-faint);
		margin-bottom: 0.4em;
	}
	.prefs label {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		margin-right: 1.25em;
		font-size: 13.5px;
		color: var(--ink);
		cursor: pointer;
	}
	.prefs input[type="radio"] {
		accent-color: var(--ink);
	}
	button[type="submit"] {
		align-self: flex-start;
		padding: 0.55em 1.1em;
		border: 1px solid var(--ink);
		background: var(--ink);
		color: var(--bg);
		font-size: 13px;
		font-weight: 600;
		font-family: var(--font-stack-sans);
		letter-spacing: 0.02em;
		cursor: pointer;
		transition: background 0.12s ease, color 0.12s ease;
	}
	button[type="submit"]:hover {
		background: var(--bg);
		color: var(--ink);
	}
	button[type="submit"]:disabled {
		opacity: 0.6;
		cursor: default;
	}
	.confirm {
		margin: 0;
		color: var(--ink-muted);
		font-size: 13px;
		line-height: 1.45;
	}
	.confirm.error {
		color: #b00020;
	}
	.confirm[hidden] { display: none; }
</style>

<script is:inline>
	(function () {
		var form = document.getElementById('newsletter-form');
		if (!form) return;
		var action = form.getAttribute('data-action');
		var status = form.querySelector('.confirm');

		function show(msg, isError) {
			if (!status) return;
			status.textContent = msg;
			status.hidden = false;
			if (isError) {
				status.classList.add('error');
			} else {
				status.classList.remove('error');
			}
		}

		form.addEventListener('submit', function (e) {
			e.preventDefault();
			var email = (form.querySelector('input[name="email"]') || {}).value || '';
			var pref = (form.querySelector('input[name="pref"]:checked') || {}).value || 'both';
			if (!email || email.indexOf('@') === -1) {
				show('Please enter a valid email.', true);
				return;
			}

			// Fire the intent event first, before any navigation or async work.
			if (window.posthog && typeof window.posthog.capture === 'function') {
				window.posthog.capture('newsletter_signup_intent', { preference: pref });
			}

			var btn = form.querySelector('button[type="submit"]');
			if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }

			var body = new URLSearchParams();
			body.append('email', email);
			body.append('tag', pref);
			body.append('embed', '1');

			fetch(action, { method: 'POST', mode: 'no-cors', body: body })
				.then(function () {
					show('Check your inbox. Click the confirmation link and you are in.', false);
					form.reset();
				})
				.catch(function () {
					show('Something went wrong. Try again, or email me at neumanic2@gmail.com.', true);
				})
				.then(function () {
					if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
				});
		});
	})();
</script>
