---
interface Category {
	name: string;
	percent: number;
	minutes: number;
}

interface App {
	name: string;
	minutes: number;
}

import { useJournal, type Locale } from '../i18n/ui';

interface Props {
	focusTime?: string;
	topCategories?: Category[];
	topApps?: App[];
	rizePartial?: boolean;
	lang?: Locale;
}

const { focusTime, topCategories = [], topApps = [], rizePartial = false, lang = 'en' } = Astro.props;
const rz = useJournal(lang).rize;

const visibleCategories = topCategories.slice(0, 5);
const visibleApps = topApps.slice(0, 6);

const formatMinutes = (mins: number): string => {
	if (mins < 60) return `${mins}m`;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return m === 0 ? `${h}h` : `${h}h ${m}m`;
};
---

<aside class="rize-recap" aria-label="Screen-time summary from Rize">
	<header class="rize-head">
		<span class="rize-label">{rz.onScreen}</span>
		<span class="rize-time">{focusTime}</span>
		{rizePartial && <span class="rize-partial" title="Rize tracking was off for part of this day">{rz.partialDay}</span>}
	</header>

	{visibleCategories.length > 0 && (
		<div class="rize-section">
			<div class="rize-section-label">{rz.topCategories}</div>
			<ul class="rize-list">
				{visibleCategories.map((c) => (
					<li class="rize-row">
						<span class="rize-row-name">{c.name}</span>
						<span class="rize-bar" aria-hidden="true">
							<span class="rize-bar-fill" style={`width: ${Math.min(c.percent, 100)}%`}></span>
						</span>
						<span class="rize-row-meta">{c.percent}% &middot; {formatMinutes(c.minutes)}</span>
					</li>
				))}
			</ul>
		</div>
	)}

	{visibleApps.length > 0 && (
		<div class="rize-section">
			<div class="rize-section-label">{rz.topApps}</div>
			<ul class="rize-app-list">
				{visibleApps.map((a) => (
					<li class="rize-app">
						<span class="rize-app-name">{a.name}</span>
						<span class="rize-app-time">{formatMinutes(a.minutes)}</span>
					</li>
				))}
			</ul>
		</div>
	)}

	<footer class="rize-foot">
		<span>{rz.trackedWith} <a href="https://rize.io" target="_blank" rel="noopener">Rize</a></span>
	</footer>
</aside>

<style>
	.rize-recap {
		margin: 0 0 2em 0;
		padding: 0.85em 1em;
		border: 1px solid var(--rule);
		background: transparent;
		font-size: 13px;
		line-height: 1.4;
		color: var(--ink);
	}
	.rize-head {
		display: flex;
		align-items: baseline;
		gap: 0.75em;
		margin-bottom: 0.75em;
		padding-bottom: 0.55em;
		border-bottom: 1px solid var(--rule);
	}
	.rize-label {
		font-family: var(--font-stack-sans);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-faint);
	}
	.rize-time {
		font-family: var(--font-stack-mono);
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--ink);
		letter-spacing: -0.01em;
	}
	.rize-partial {
		margin-left: auto;
		padding: 0.15em 0.55em;
		border: 1px solid var(--rule);
		background: var(--bg);
		font-size: 10px;
		color: var(--ink-faint);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.rize-section + .rize-section {
		margin-top: 0.85em;
	}
	.rize-section-label {
		margin-bottom: 0.4em;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-faint);
	}
	.rize-list,
	.rize-app-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.rize-row {
		display: grid;
		grid-template-columns: minmax(5.5em, 1fr) minmax(0, 2fr) auto;
		gap: 0.75em;
		align-items: center;
		padding: 0.2em 0;
	}
	.rize-row-name {
		font-weight: 500;
		color: var(--ink);
		font-size: 13px;
	}
	.rize-bar {
		display: block;
		height: 4px;
		background: var(--rule);
		overflow: hidden;
	}
	.rize-bar-fill {
		display: block;
		height: 100%;
		background: var(--ink);
	}
	.rize-row-meta {
		font-family: var(--font-stack-mono);
		font-variant-numeric: tabular-nums;
		font-size: 11px;
		color: var(--ink-faint);
		white-space: nowrap;
	}
	.rize-app-list {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.15em 1.5em;
	}
	.rize-app {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5em;
		padding: 0.15em 0;
		font-size: 12.5px;
	}
	.rize-app-name {
		color: var(--ink);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.rize-app-time {
		font-family: var(--font-stack-mono);
		font-variant-numeric: tabular-nums;
		color: var(--ink-faint);
		font-size: 11px;
	}
	.rize-foot {
		margin-top: 0.85em;
		padding-top: 0.55em;
		border-top: 1px solid var(--rule);
		font-size: 10px;
		color: var(--ink-faint);
		text-align: right;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.rize-foot a {
		color: var(--ink-faint);
		text-decoration: underline;
		text-decoration-color: var(--rule);
	}
	.rize-foot a:hover {
		color: var(--ink);
	}
	@media (max-width: 540px) {
		.rize-app-list {
			grid-template-columns: 1fr;
		}
		.rize-row {
			grid-template-columns: minmax(5em, 1fr) minmax(0, 1.5fr) auto;
		}
	}
</style>
