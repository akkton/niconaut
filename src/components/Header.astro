---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Localized sections get a locale prefix; en stays at the root (no trailing slash,
// so HeaderLink active-state matching keeps working). Work stays English for now.
const sec = (seg: string) => (lang === 'en' ? `/${seg}` : `/${lang}/${seg}`);
const home = lang === 'en' ? '/' : `/${lang}/`;
---

<header>
	<nav>
		<a class="brand" href={home}>nicolasneumann.blog</a>
		<div class="internal-links">
			<HeaderLink href={sec('journal')}>{t.nav.journal}</HeaderLink>
			<HeaderLink href={sec('posts')}>{t.nav.posts}</HeaderLink>
			<HeaderLink href={sec('projects')}>{t.nav.building}</HeaderLink>
			<HeaderLink href="/work">{t.nav.work}</HeaderLink>
			<HeaderLink href={sec('about')}>{t.nav.about}</HeaderLink>
			<HeaderLink href={sec('feedback')}>{t.nav.feedback}</HeaderLink>
			<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle color theme">◐</button>
			<LanguageSwitcher />
		</div>
	</nav>
</header>
<script is:inline>
	(function () {
		var btn = document.getElementById('theme-toggle');
		if (!btn) return;
		function current() {
			var t = document.documentElement.dataset.theme;
			if (t === 'dark' || t === 'light') return t;
			try {
				return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			} catch (e) { return 'light'; }
		}
		function syncLabel() {
			var c = current();
			btn.setAttribute('aria-label', c === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
		}
		btn.addEventListener('click', function () {
			var next = current() === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			try { localStorage.setItem('theme', next); } catch (e) { /* ignore */ }
			syncLabel();
		});
		syncLabel();
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0;
		background: var(--bg);
		border-bottom: 1px solid var(--rule);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 680px;
		margin: 0 auto;
		padding: 0.85em 1em;
		gap: 1.5em;
	}
	.brand {
		font-family: var(--font-stack-sans);
		font-size: 14px;
		font-weight: 600;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.005em;
	}
	.brand:hover {
		color: var(--link-hover);
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
			align-items: center;
			gap: 0.5em 1.1em;
	}
	.internal-links a {
		font-size: 14px;
		color: var(--ink-muted);
		text-decoration: none;
		padding: 0.25em 0; white-space: nowrap;
		transition: color 0.12s ease;
	}
	.internal-links a:hover {
		color: var(--ink);
	}
	.internal-links a.active {
		color: var(--ink);
		text-decoration: underline;
		text-decoration-color: var(--ink);
		text-underline-offset: 5px;
		font-weight: 500;
	}
	.theme-toggle {
		font-family: var(--font-stack-sans);
		font-size: 15px;
		line-height: 1;
		color: var(--ink-faint);
		background: transparent;
		border: none;
		padding: 0;
		margin: 0;
		cursor: pointer;
		transition: color 0.12s ease;
	}
	.theme-toggle:hover {
		color: var(--ink);
	}
	.theme-toggle:focus-visible {
		outline: 1px solid var(--ink);
		outline-offset: 3px;
		border-radius: 2px;
	}
	@media (max-width: 540px) {
		nav {
			padding: 0.7em 1em;
			gap: 1em;
		}
		.internal-links {
			gap: 0.9em;
		}
	}
</style>
