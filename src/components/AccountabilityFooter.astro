---
interface Props {
	targets?: string[];
	wins?: string[];
	losses?: string[];
	lessons?: string[];
}

const { targets, wins, losses, lessons } = Astro.props;
const hasAny =
	(targets && targets.length > 0) ||
	(wins && wins.length > 0) ||
	(losses && losses.length > 0) ||
	(lessons && lessons.length > 0);
---

{hasAny && (
	<section class="accountability" aria-label="Day accountability">
		{targets && targets.length > 0 && (
			<div class="block">
				<h3 class="block-label">Targets</h3>
				<ul>
					{targets.map((t) => <li>{t}</li>)}
				</ul>
			</div>
		)}
		<div class="grid">
			{wins && wins.length > 0 && (
				<div class="block wins">
					<h3 class="block-label">Wins</h3>
					<ul>
						{wins.map((w) => <li>{w}</li>)}
					</ul>
				</div>
			)}
			{losses && losses.length > 0 && (
				<div class="block losses">
					<h3 class="block-label">Losses</h3>
					<ul>
						{losses.map((l) => <li>{l}</li>)}
					</ul>
				</div>
			)}
			{lessons && lessons.length > 0 && (
				<div class="block lessons">
					<h3 class="block-label">Lessons</h3>
					<ul>
						{lessons.map((l) => <li>{l}</li>)}
					</ul>
				</div>
			)}
		</div>
	</section>
)}

<style>
	.accountability {
		margin: 2.5em 0 1em 0;
		padding-top: 1.5em;
	}
	.block {
		margin-bottom: 1.5em;
	}
	.block-label {
		margin: 0 0 0.65em 0;
		font-family: var(--font-stack-sans);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-faint);
	}
	.block ul {
		margin: 0;
		padding-left: 1.1em;
		list-style-type: none;
	}
	.block li {
		position: relative;
		margin-bottom: 0.4em;
		padding-left: 0.5em;
		line-height: 1.5;
		color: var(--ink);
		font-size: 13.5px;
	}
	.block li::before {
		content: "·";
		position: absolute;
		left: -1.1em;
		color: var(--ink-faint);
		font-family: var(--font-stack-mono);
		font-size: 0.85em;
	}
	.grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 1.75em;
	}
	.wins .block-label { color: #2a7548; }
	.losses .block-label { color: #9c3636; }
	.lessons .block-label { color: var(--ink-muted); }
	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
			gap: 1.25em;
		}
	}
</style>
