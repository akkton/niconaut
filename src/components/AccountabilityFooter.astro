---
import { useJournal, type Locale } from '../i18n/ui';

interface Props {
	targets?: string[];
	wins?: string[];
	losses?: string[];
	lessons?: string[];
	lang?: Locale;
}

const { targets, wins, losses, lessons, lang = 'en' } = Astro.props;
const acc = useJournal(lang).acc;
const hasAny =
	(targets && targets.length > 0) ||
	(wins && wins.length > 0) ||
	(losses && losses.length > 0) ||
	(lessons && lessons.length > 0);
---

{hasAny && (
	<section class="accountability" aria-label="Day accountability">
		{targets && targets.length > 0 && (
			<div class="block targets">
				<h3 class="block-label">{acc.targets}</h3>
				<ul>
					{targets.map((t) => <li>{t}</li>)}
				</ul>
			</div>
		)}
		<div class="grid">
			{wins && wins.length > 0 && (
				<div class="block wins">
					<h3 class="block-label">{acc.wins}</h3>
					<ul>
						{wins.map((w) => <li>{w}</li>)}
					</ul>
				</div>
			)}
			{losses && losses.length > 0 && (
				<div class="block losses">
					<h3 class="block-label">{acc.losses}</h3>
					<ul>
						{losses.map((l) => <li>{l}</li>)}
					</ul>
				</div>
			)}
			{lessons && lessons.length > 0 && (
				<div class="block lessons">
					<h3 class="block-label">{acc.lessons}</h3>
					<ul>
						{lessons.map((l) => <li>{l}</li>)}
					</ul>
				</div>
			)}
		</div>
	</section>
)}

<style>
	.accountability {
		margin: 2.5em 0 1em 0;
		padding-top: 1.75em;
		border-top: 1px solid var(--rule);
	}
	.block {
		margin: 0 0 1em 0;
		padding: 0.9em 1.1em 1em 1.15em;
		border: 1px solid var(--rule);
		border-left: 3px solid var(--rule-strong);
		border-radius: 5px;
	}
	.block-label {
		margin: 0 0 0.65em 0;
		font-family: var(--font-stack-sans);
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-faint);
	}
	.block ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.block li {
		position: relative;
		margin-bottom: 0.5em;
		padding-left: 1.1em;
		line-height: 1.55;
		color: var(--ink);
		font-size: 13.5px;
	}
	.block li:last-child {
		margin-bottom: 0;
	}
	.block li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.6em;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--ink-faint);
		opacity: 0.7;
	}
	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1em;
	}
	.grid .block {
		margin: 0;
	}
	.targets {
		border-left-color: var(--ink-faint);
	}
	.wins {
		border-left-color: #2a7548;
	}
	.losses {
		border-left-color: #9c3636;
	}
	.lessons {
		border-left-color: var(--rule-strong);
	}
	.wins .block-label {
		color: #2a7548;
	}
	.losses .block-label {
		color: #9c3636;
	}
	.lessons .block-label {
		color: var(--ink-muted);
	}
	.wins li::before {
		background: #2a7548;
		opacity: 0.8;
	}
	.losses li::before {
		background: #9c3636;
		opacity: 0.8;
	}
	@media (min-width: 721px) {
		.grid {
			grid-template-columns: 1fr 1fr;
		}
		.lessons {
			grid-column: 1 / -1;
		}
	}
</style>
