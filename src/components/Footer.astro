<style>
	footer {
		margin-top: 4em;
		padding: 1.5em 1em;
		border-top: 1px solid var(--rule);
		background: var(--bg);
		font-size: 12px;
	}
	.inner {
		max-width: 680px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1em;
	}
	.copy {
		color: var(--ink-faint);
		letter-spacing: 0.01em;
	}
	.copy a.rss {
		color: var(--ink-faint);
		text-decoration: underline;
		text-decoration-color: var(--rule);
	}
	.copy a.rss:hover {
		color: var(--ink);
	}
	.social-links {
		display: flex;
		gap: 1em;
	}
	.social-links a {
		color: var(--ink-faint);
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		transition: color 0.12s ease;
	}
	.social-links a:hover {
		color: var(--ink);
	}
	@media (max-width: 540px) {
		.inner {
			flex-direction: column;
			gap: 0.85em;
			align-items: flex-start;
		}
	}
</style>
